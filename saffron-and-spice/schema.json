        {
          "@type": "Question",
          "name": "Do I need to make a reservation in advance?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Walk-ins are welcome on weekdays. We strongly recommend reserving at least 48 hours in advance for weekends and special occasions. Book online or call +91 40 4567 8900."
          }
        },
        {
          "@type": "Question",
          "name": "Does Saffron & Spice offer vegetarian options?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Over 40% of our menu is vegetarian. We also offer vegan, Jain-friendly, and gluten-free options. Please inform us of dietary requirements when booking."
          }
        },
        {
          "@type": "Question",
          "name": "Is parking available at Saffron & Spice?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Complimentary valet parking is available for all dining guests. We also have a private basement parking lot with capacity for 80+ vehicles."
          }
        },
        {
          "@type": "Question",
          "name": "Can I host a private event or corporate dinner at Saffron & Spice?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. We have two private dining rooms — The Mughal Suite (up to 20 guests) and The Garden Pavilion (up to 50 guests). Contact our events team at events@saffronandspice.com for custom packages."
          }
        },
        {
          "@type": "Question",
          "name": "What are your opening hours?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We are open every day. Lunch: 12:00 PM – 3:30 PM. Dinner: 7:00 PM – 11:00 PM (11:30 PM on Fridays and Saturdays). Open on all public holidays."
          }
        }
      ]
